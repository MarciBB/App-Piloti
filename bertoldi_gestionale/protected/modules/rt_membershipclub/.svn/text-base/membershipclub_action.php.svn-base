function checkEmail(){
	global $db;
	$email = $_POST['email'];
	$sql = "SELECT * FROM RT_MembershipClub WHERE Email = '$email'";
	$row = $db->fetch_array($sql);
	if(count($row) == 0){
		echo json_encode(array('result'=>true));
	} else {
		echo json_encode(array('result'=>false));
	}
}


function update()
